{
  "manifest_version": 3,
  "name": "Cognitive Mode",
  "version": "0.1.0",
  "description": "Introduces intentional friction into AI prompting workflows.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cognitive Mode",
    "default_icon": {
      "48": "favicon.svg",
      "128": "favicon.svg"
    }
  },
  "icons": {
    "48": "favicon.svg",
    "128": "favicon.svg"
  },
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://v0.dev/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://v0.dev/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://v0.dev/*"
      ]
    }
  ]
}
